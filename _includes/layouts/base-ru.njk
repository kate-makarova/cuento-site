<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Special+Elite&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  {% for css in extraCss %}
  <link rel="stylesheet" href="{{ css }}" />
  {% endfor %}
</head>
<body>

  <nav class="nav">
    <a href="/ru/" class="nav-logo">
      <img src="/assets/cuento-claw-full.png" alt="Cuento" class="nav-logo-img" />
      <span>Cuento</span>
    </a>
    {% if navStyle == "main" %}
    <div class="nav-links">
      <a href="/ru/#features">Возможности</a>
      <a href="/ru/#open-source">Открытый код</a>
      <a href="/ru/cli/">CLI</a>
      <a href="/ru/docs/">Документация</a>
      <a href="https://github.com/topics/cuento-pbp" class="btn-sketch btn-small">GitHub ↗</a>
    </div>
    {% elif navStyle == "cli" %}
    <div class="nav-links">
      <a href="#install">Установка</a>
      <a href="#commands">Команды</a>
      <a href="#config">Конфигурация</a>
      <a href="https://github.com/kate-makarova/cuento-cli/releases/latest" class="btn-sketch btn-small">Скачать ↗</a>
    </div>
    {% elif navStyle == "docs" %}
    <div class="nav-links">
      <a href="/ru/docs/">Документация</a>
      <a href="/ru/cli/">CLI</a>
    </div>
    {% endif %}
  </nav>

  {{ content | safe }}

  <footer class="footer">
    <div class="container footer-inner">
      <span class="footer-brand">Cuento</span>
      <div class="footer-links">
        <a href="https://github.com/topics/cuento-pbp">GitHub</a>
        <a href="/ru/docs/">Документация</a>
        <a href="/ru/cli/">CLI</a>
      </div>
      <span class="footer-copy">Создано с чернилами и воображением.</span>
    </div>
  </footer>

</body>
</html>
