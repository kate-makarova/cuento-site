  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="container">
      <div class="section-label">what is cuento?</div>
      <p class="about-text">
        Play-by-post (PbP) is a style of collaborative storytelling where participants take turns writing
        their characters' actions, thoughts, and dialogue — like a never-ending novel written by many hands.
        Cuento gives you a dedicated space to do exactly that, without ads, algorithms, or noise.
      </p>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-label">features</div>
      <h2 class="section-title">Everything a storyteller needs.</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">&#128203;</div>
          <h3>Customizable Character Sheets</h3>
          <p>Design character sheets and game topics that fit your world — any system, any genre, fully your own.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128276;</div>
          <h3>Live Updates &amp; Notifications</h3>
          <p>Never miss a post. Get real-time updates when your story moves forward and stay in the moment.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#127912;</div>
          <h3>Customizable Design</h3>
          <p>Make it yours — choose themes, colours, and layouts that match the mood of your world.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#128274;</div>
          <h3>E2E Encrypted Messages</h3>
          <p>Direct messages are end-to-end encrypted. Your private conversations stay private, always.</p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">&#9881;</div>
          <h3>Self-Hosted</h3>
          <p>Run Cuento on your own server. Your stories, your data, forever under your control.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how" id="how">
    <div class="container">
      <div class="section-label">how it works</div>
      <h2 class="section-title">Three steps to a new world.</h2>
